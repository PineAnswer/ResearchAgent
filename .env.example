# Deep Agents model reference. The default uses the LangChain OpenAI integration.
RESEARCH_AGENT_MODEL=openai:gpt-4.1-mini
OPENAI_API_KEY=

# Free key: https://openalex.org/settings/api
OPENALEX_API_KEY=
# Optional contact email for OpenAlex/Crossref polite usage.
OPENALEX_EMAIL=

# Per literature-scout run. Change these values without editing Python code.
RESEARCH_AGENT_MAX_OPENALEX_SEARCHES=3
RESEARCH_AGENT_MAX_CROSSREF_SEARCHES=1
# Distinct network fetch requests allowed for one paper. Reader model and local-PDF
# extraction limits are enforced separately in the Agent registry.
RESEARCH_AGENT_MAX_PAPER_FETCHES_PER_PAPER=2
RESEARCH_AGENT_SEARCH_MAX_RETRIES=3
RESEARCH_AGENT_SEARCH_BACKOFF_SECONDS=1.0
RESEARCH_AGENT_SEARCH_MAX_RETRY_WAIT_SECONDS=30.0
# Human search-review limits. Duplicate suggestions do not consume a round.
RESEARCH_AGENT_MAX_SEARCH_REVIEW_ROUNDS=3
RESEARCH_AGENT_MAX_SUGGESTED_QUERIES_PER_ROUND=3

# Optional OpenAI-compatible endpoint, such as a self-hosted gateway.
RESEARCH_AGENT_BASE_URL=

# Local runtime files and SQLite database are stored here.
RESEARCH_AGENT_DATA_DIR=.research-agent
RESEARCH_AGENT_ENABLE_FALLBACK=true
RESEARCH_AGENT_API_HOST=127.0.0.1
RESEARCH_AGENT_API_PORT=8000

# Optional LangSmith tracing.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=evidence-research-agent-demo
